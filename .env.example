# SOP — Environment Variables
# Copy this file to .env and fill in the values for local development.
# In production these come from the SOPS_SECRETS_JSON GitHub secret, which the
# deploy workflow turns into the Kubernetes `sops-secrets` secret.

# Flask session signing key
SECRET_KEY=change-me

# Local-dev only: which brand to render when the host isn't a brand host
# (sops.gourmiz.fr / sops.essenciagua.fr / sops.sablesienne.com). In production
# the brand is forced by the request host. Values: gourmiz | essenciagua | sablesienne
SOPS_DEFAULT_BRAND=sablesienne

# Database (MySQL on OVH) — section `database-ovh`
DATABASE_OVH__HOST=localhost
DATABASE_OVH__PORT=3306
DATABASE_OVH__USER=root
DATABASE_OVH__PASSWORD=
DATABASE_OVH__NAME=sops

# Google OAuth. Two clients are registered; the active one is chosen per host:
#   gourmiz + essenciagua  -> google-auth-lesbonneschoses
#   sablesienne            -> google-auth-sablesienne
# Authorized redirect URIs to register in each Google client:
#   https://sops.gourmiz.fr/auth/login/google/callback        (lesbonneschoses client)
#   https://sops.essenciagua.fr/auth/login/google/callback    (lesbonneschoses client)
#   https://sops.sablesienne.com/auth/login/google/callback   (sablesienne client)
#   http://localhost:5008/auth/login/google/callback          (for local dev)
GOOGLE_AUTH_LESBONNESCHOSES__CLIENT_ID=
GOOGLE_AUTH_LESBONNESCHOSES__CLIENT_SECRET=
GOOGLE_AUTH_SABLESIENNE__CLIENT_ID=
GOOGLE_AUTH_SABLESIENNE__CLIENT_SECRET=

# SendGrid SMTP — email login codes (for accounts off the Google OAuth domain)
SENDGRID__API_KEY=
SENDGRID__FROM_EMAIL=
SENDGRID__FROM_NAME=

# OVH Object Storage (S3-compatible) — media library — section `ovh`
OVH__ENDPOINT_URL=https://s3.eu-west-par.io.cloud.ovh.net/
OVH__BUCKET=sops-storage
OVH__REGION=eu-west-par
OVH__ACCESS_KEY=
OVH__SECRET_KEY=

# Redis (only used when CACHE_TYPE=RedisCache, e.g. in Kubernetes)
# CACHE_TYPE=RedisCache
# REDIS_HOST=redis-service
# REDIS_PORT=6379
